#include <stdio.h>
#include <string.h>

#include "lwip/udp.h"
#include "lwip/ip_addr.h"

#include "xil_printf.h"
#include "xil_cache.h"

#include "display_demo.h"
#include "display_ctrl/display_ctrl.h"

/* ========================================================= */
/* VIDEO CONFIG                                              */
/* ========================================================= */
#define WIDTH       640
#define HEIGHT      480
#define BPP         4

#define FRAME_SIZE  (WIDTH * HEIGHT * BPP)

/* ========================================================= */
/* FRAME BUFFERS                                             */
/* ========================================================= */
#define FB1 0x10000000U
#define FB2 0x10200000U
#define FB3 0x10400000U

static u32 fb_list[3] = {FB1, FB2, FB3};

extern DisplayCtrl dispCtrl;

/* ========================================================= */
/* UDP FRAME STATE                                           */
/* ========================================================= */

// incoming frame tracking
static u32 current_frame_id = 0xFFFFFFFF;
static u32 received_chunks = 0;
static u32 expected_chunks = 0;

// framebuffer write
static u32 offset = 0;
static int write_index = 2;

/* ========================================================= */
/* UDP RECEIVE CALLBACK                                      */
/* ========================================================= */

#define HEADER_SIZE 12   // frame_id, chunk_id, total_chunks

void udp_recv_callback(void *arg,
                       struct udp_pcb *pcb,
                       struct pbuf *p,
                       const ip_addr_t *addr,
                       u16_t port)
{
    if (!p) return;

    u8 *payload = (u8 *)p->payload;

    // ✅ READ HEADER
    u32 frame_id      = *((u32 *)(payload + 0));
    u32 chunk_id      = *((u32 *)(payload + 4));
    u32 total_chunks  = *((u32 *)(payload + 8));

    u8 *data = payload + HEADER_SIZE;
    u32 data_len = p->len - HEADER_SIZE;

    /* ================= NEW FRAME ================= */
    if (frame_id != current_frame_id)
    {
        current_frame_id = frame_id;
        received_chunks = 0;
        expected_chunks = total_chunks;
        offset = 0;
    }

    /* ================= WRITE DATA ================= */
    u32 fb_addr = fb_list[write_index];
    u8 *fb = (u8 *)fb_addr;

    if (offset + data_len <= FRAME_SIZE)
    {
        memcpy(&fb[offset], data, data_len);
        offset += data_len;
    }

    received_chunks++;

    /* ================= COMPLETE FRAME ================= */
    if (received_chunks == expected_chunks && offset == FRAME_SIZE)
    {
        Xil_DCacheFlushRange((UINTPTR)fb_addr, FRAME_SIZE);

        xil_printf("Frame complete -> FB%d ✅\r\n", write_index + 1);

        /* ✅ DISPLAY FRAME (YOUR LOGIC) */
        DisplayChangeFrame(&dispCtrl, write_index);

        /* ✅ SAFE BUFFER SWITCH (YOUR LOGIC PRESERVED) */
        int display_index = dispCtrl.curFrame;
        write_index = (display_index + 2) % 3;

        offset = 0;
    }

    pbuf_free(p);
}

/* ========================================================= */
/* START UDP SERVER                                          */
/* ========================================================= */

int start_application(void)
{
    struct udp_pcb *pcb;

    pcb = udp_new();
    if (!pcb)
    {
        xil_printf("UDP PCB create failed\r\n");
        return -1;
    }

    if (udp_bind(pcb, IP_ANY_TYPE, 6001) != ERR_OK)
    {
        xil_printf("UDP bind failed\r\n");
        return -1;
    }

    udp_recv(pcb, udp_recv_callback, NULL);

    xil_printf("UDP Video Server Ready @ Port 6001\r\n");
    xil_printf("Resolution : %dx%d\r\n", WIDTH, HEIGHT);
    xil_printf("Frame Size : %d bytes\r\n", FRAME_SIZE);

    return 0;
}
