#include <stdio.h>
#include <string.h>

#include "lwip/err.h"
#include "lwip/tcp.h"
#include "xil_printf.h"
#include "xil_cache.h"
#include "display_demo.h"
#include "display_ctrl/display_ctrl.h"
/* VIDEO CONFIG */
#define WIDTH   640
#define HEIGHT  480
#define BPP     4
#define FRAME_SIZE (WIDTH * HEIGHT * BPP)

/* ✅ 3 FRAME BUFFERS */
#define FB1 0x10000000U
#define FB2 0x10200000U
#define FB3 0x10400000U

static u32 fb_list[3] = {FB1, FB2, FB3};

/* ✅ write index */


/* ✅ offset */
static u32 offset = 0;

/* extern display */
extern DisplayCtrl dispCtrl;

/* ================= RECEIVE ================= */
err_t recv_callback(void *arg, struct tcp_pcb *tpcb,
                    struct pbuf *p, err_t err)
{
    if (!p) {
        tcp_close(tpcb);
        tcp_recv(tpcb, NULL);
        return ERR_OK;
    }

    tcp_recved(tpcb, p->tot_len);

    /* ✅ GET CURRENT DISPLAY BUFFER */
    int display_index = dispCtrl.curFrame;

    /* ✅ FIND SAFE BUFFER (NOT CURRENT OR NEXT) */
    int safe_index = (display_index + 2) % 3;

    /* ✅ WRITE ONLY TO SAFE BUFFER */
    u32 fb_addr = fb_list[safe_index];
    u8 *fb = (u8 *)fb_addr;

    struct pbuf *q = p;

    while (q != NULL)
    {
        u8 *payload = (u8 *)q->payload;

        for (u32 i = 0; i < q->len; i++)
        {
            if (offset < FRAME_SIZE)
                fb[offset++] = payload[i];

            if (offset == FRAME_SIZE)
            {
                Xil_DCacheFlushRange(fb_addr, FRAME_SIZE);

                xil_printf("Frame done ✅\n");

                offset = 0;

                /* ✅ tell VDMA to display NEW safe buffer */
                DisplayChangeFrame(&dispCtrl, safe_index);

                pbuf_free(p);
                return ERR_OK;
            }
        }

        q = q->next;
    }

    pbuf_free(p);
    return ERR_OK;
}
/* ================= ACCEPT CALLBACK ================= */
err_t accept_callback(void *arg, struct tcp_pcb *newpcb, err_t err)
{
    /* Set receive callback */
    tcp_recv(newpcb, recv_callback);

    xil_printf("Client connected ✅\r\n");

    return ERR_OK;
}

/* ================= START TCP SERVER ================= */
int start_application(void)
{
    struct tcp_pcb *pcb;

    pcb = tcp_new_ip_type(IPADDR_TYPE_ANY);

    if (!pcb) {
        xil_printf("TCP PCB alloc failed ❌\r\n");
        return -1;
    }

    if (tcp_bind(pcb, IP_ANY_TYPE, 6001) != ERR_OK) {
        xil_printf("TCP bind failed ❌\r\n");
        return -1;
    }

    pcb = tcp_listen(pcb);

    tcp_accept(pcb, accept_callback);

    xil_printf("TCP Server Ready ✅\r\n");

    return 0;
}
